<%- include('partials/header') %>
<div class="page-header">
  <div class="page-title">Módulo de Liquidação<small><%= cliente.nome %></small></div>
  <a href="/clientes/<%= cliente._id %>" class="btn btn-outline btn-sm"><i class="fas fa-arrow-left"></i> Voltar ao Dossiê</a>
</div>
<form action="/clientes/<%= cliente._id %>/cumprimento" method="POST">
  <div class="grid" style="max-width:900px;margin:0 auto;gap:1.25rem">
    <div class="card card--green">
      <div class="card-header"><div class="card-header-title"><div class="icon" style="background:var(--green-bg);color:var(--green)"><i class="fas fa-landmark"></i></div>1. Parâmetros da Condenação</div></div>
      <div class="card-body">
        <div class="params-grid">
          <div class="form-group"><label class="form-label">Tipo de Execução</label><select name="contra_fazenda" class="form-select"><option value="0" <%=!execucao.contra_fazenda?'selected':''%>>Particular (Art. 523 CPC)</option><option value="1" <%=execucao.contra_fazenda?'selected':''%>>Fazenda Pública (INSS/União)</option></select></div>
          <div class="form-group"><label class="form-label">Trânsito em Julgado</label><input type="date" name="data_transito" class="form-control" value="<%=execucao.data_transito?moment(execucao.data_transito).format('YYYY-MM-DD'):''%>"></div>
          <div class="form-group"><label class="form-label">Valor Histórico (R$)</label><input type="number" step="0.01" name="valor_principal" class="form-control" value="<%=execucao.valor_principal||''%>" placeholder="50000.00"></div>
          <div class="form-group"><label class="form-label">Honorários Conhecimento (%)</label><input type="number" step="0.1" name="honorarios_conhecimento" class="form-control" value="<%=execucao.honorarios_conhecimento||''%>" placeholder="10"></div>
        </div>
      </div>
    </div>
    <div class="card card--gold">
      <div class="card-header"><div class="card-header-title"><div class="icon" style="background:var(--gold-bg);color:var(--gold)"><i class="fas fa-chart-line"></i></div>2. Motores de Atualização Monetária</div></div>
      <div class="card-body">
        <div class="grid grid-3 gap-4">
          <div class="form-group"><label class="form-label">Data do Cálculo</label><input type="date" name="data_atualizacao" class="form-control" value="<%=execucao.data_atualizacao?moment(execucao.data_atualizacao).format('YYYY-MM-DD'):''%>"></div>
          <div class="form-group"><label class="form-label">Índice de Correção</label><select name="indice_correcao" class="form-select"><option value="INPC" <%=execucao.indice_correcao==='INPC'?'selected':''%>>INPC (Regra Geral)</option><option value="IPCA-E" <%=execucao.indice_correcao==='IPCA-E'?'selected':''%>>IPCA-E (Fazenda até 2021)</option><option value="TJDFT" <%=execucao.indice_correcao==='TJDFT'?'selected':''%>>Tabela TJDFT</option></select></div>
          <div class="form-group"><label class="form-label">Termo Inicial dos Juros</label><select name="termo_inicial_juros" class="form-select"><option value="citação" <%=execucao.termo_inicial_juros==='citação'?'selected':''%>>Da Citação</option><option value="mora" <%=execucao.termo_inicial_juros==='mora'?'selected':''%>>Da Mora Administrativa</option><option value="requerimento" <%=execucao.termo_inicial_juros==='requerimento'?'selected':''%>>Do Requerimento (DER)</option></select></div>
          <div class="form-group"><label class="form-label">Taxa de Juros</label><select name="taxa_juros" class="form-select"><option value="1% a.m." <%=execucao.taxa_juros==='1% a.m.'?'selected':''%>>1% ao mês (Art. 406 CC)</option><option value="Selic" <%=execucao.taxa_juros==='Selic'?'selected':''%>>Taxa Selic (EC 113/2021)</option><option value="Poupança" <%=execucao.taxa_juros==='Poupança'?'selected':''%>>Índice da Poupança</option></select></div>
        </div>
      </div>
    </div>
    <div class="flex justify-end"><button type="submit" class="btn btn-primary btn-lg"><i class="fas fa-save"></i> Salvar Dados de Liquidação</button></div>
  </div>
</form>
<%- include('partials/footer') %>
